/* pages/watchlist/watchlist.wxss */
/* 标的页样式 v4.0 */

.page-container {
  padding-bottom: 20rpx;
}

/* ========== 板块标签栏 ========== */
.sector-tabs {
  background: #fff;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
  position: sticky;
  top: 0;
  z-index: 10;
}

.sector-scroll {
  white-space: nowrap;
  padding: 0 24rpx;
}

.sector-item {
  display: inline-block;
  padding: 10rpx 28rpx;
  font-size: 26rpx;
  color: #666;
  border-radius: 28rpx;
  margin-right: 12rpx;
  background: #f5f5f5;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.sector-active {
  background: linear-gradient(135deg, #FFB800, #FF8C00);
  color: #fff;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(255, 184, 0, 0.3);
  transform: scale(1.05);
}

/* ========== 板块概览 ========== */
.sector-overview-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin: 16rpx 24rpx 8rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.06);
  border-top: 4rpx solid #FFB800;
  opacity: 0;
  transform: translateY(10rpx);
  transition: all 0.4s ease;
}

.overview-show {
  opacity: 1;
  transform: translateY(0);
}

.sector-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.sector-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1a2e;
}

.sector-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.7;
}

.sector-count {
  font-size: 22rpx;
  color: #bbb;
  margin-top: 12rpx;
}

/* ========== 数据截止时间 ========== */
.data-footer {
  text-align: center;
  padding: 24rpx 32rpx 16rpx;
}

.footer-text {
  font-size: 20rpx;
  color: #bbb;
}

/* ========== 板块切换过渡动画 ========== */
.sector-content {
  transition: opacity 0.2s ease, transform 0.2s ease;
}

.content-fade-out {
  opacity: 0;
  transform: translateY(10rpx);
}

.content-fade-in {
  opacity: 1;
  transform: translateY(0);
}
