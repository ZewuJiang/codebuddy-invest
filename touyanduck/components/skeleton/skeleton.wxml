<!-- skeleton 组件 — 骨架屏加载占位 -->
<view class="sk-container" wx:if="{{loading}}">

  <!-- 简报页骨架 -->
  <block wx:if="{{type === 'briefing'}}">
    <!-- 渐变头部骨架 -->
    <view class="sk-hero">
      <view class="sk-row" style="justify-content: space-between;">
        <view class="sk-block sk-shimmer-dark" style="width: 280rpx; height: 32rpx; border-radius: 8rpx;"></view>
        <view class="sk-block sk-shimmer-dark" style="width: 160rpx; height: 28rpx; border-radius: 8rpx;"></view>
      </view>
    </view>
    <!-- 核心事件卡片骨架 -->
    <view class="sk-card sk-event-card">
      <view class="sk-block sk-shimmer" style="width: 180rpx; height: 28rpx; border-radius: 8rpx; margin-bottom: 16rpx;"></view>
      <view class="sk-block sk-shimmer" style="width: 90%; height: 36rpx; border-radius: 8rpx; margin-bottom: 20rpx;"></view>
      <view class="sk-line-group" wx:for="{{3}}" wx:key="*this">
        <view class="sk-circle sk-shimmer" style="width: 16rpx; height: 16rpx;"></view>
        <view class="sk-block sk-shimmer sk-line" style="width: {{85 - index * 10}}%;"></view>
      </view>
    </view>
    <!-- 全球资产反应骨架 -->
    <view class="sk-card">
      <view class="sk-row" style="justify-content: space-between; margin-bottom: 16rpx;">
        <view class="sk-block sk-shimmer" style="width: 160rpx; height: 30rpx; border-radius: 8rpx;"></view>
        <view class="sk-block sk-shimmer" style="width: 140rpx; height: 26rpx; border-radius: 8rpx;"></view>
      </view>
      <view class="sk-grid-3">
        <view class="sk-grid-item" wx:for="{{6}}" wx:key="*this">
          <view class="sk-block sk-shimmer" style="width: 80rpx; height: 24rpx; border-radius: 6rpx; margin-bottom: 8rpx;"></view>
          <view class="sk-block sk-shimmer" style="width: 100rpx; height: 32rpx; border-radius: 6rpx;"></view>
        </view>
      </view>
    </view>
    <!-- 核心判断卡片骨架 -->
    <view class="sk-card">
      <view class="sk-block sk-shimmer" style="width: 160rpx; height: 36rpx; border-radius: 8rpx; margin-bottom: 24rpx;"></view>
      <view class="sk-judgment" wx:for="{{2}}" wx:key="*this">
        <view class="sk-row" style="margin-bottom: 12rpx;">
          <view class="sk-circle sk-shimmer" style="width: 40rpx; height: 40rpx; margin-right: 12rpx;"></view>
          <view class="sk-block sk-shimmer" style="width: 70%; height: 32rpx; border-radius: 8rpx;"></view>
        </view>
        <view class="sk-block sk-shimmer" style="width: 100%; height: 16rpx; border-radius: 8rpx; margin-bottom: 12rpx;"></view>
        <view class="sk-block sk-shimmer" style="width: 85%; height: 24rpx; border-radius: 6rpx;"></view>
      </view>
    </view>
  </block>

  <!-- 市场页骨架 -->
  <block wx:elif="{{type === 'markets'}}">
    <!-- Tab栏骨架 -->
    <view class="sk-tab-bar">
      <view class="sk-block sk-shimmer sk-tab" wx:for="{{4}}" wx:key="*this"></view>
    </view>
    <!-- 行情卡片骨架 -->
    <view class="sk-card" wx:for="{{rowArray}}" wx:key="*this">
      <view class="sk-row">
        <view class="sk-col">
          <view class="sk-block sk-shimmer" style="width: 180rpx; height: 34rpx; border-radius: 8rpx;"></view>
          <view class="sk-block sk-shimmer" style="width: 140rpx; height: 28rpx; border-radius: 6rpx; margin-top: 12rpx;"></view>
        </view>
        <view class="sk-block sk-shimmer" style="width: 120rpx; height: 40rpx; border-radius: 8rpx; margin-left: auto;"></view>
      </view>
    </view>
  </block>

  <!-- 标的页骨架 -->
  <block wx:elif="{{type === 'watchlist'}}">
    <!-- 板块Tab骨架 -->
    <view class="sk-tab-bar" style="padding: 16rpx 24rpx;">
      <view class="sk-block sk-shimmer" style="width: 120rpx; height: 48rpx; border-radius: 24rpx; margin-right: 16rpx;" wx:for="{{4}}" wx:key="*this"></view>
    </view>
    <!-- 板块概览骨架 -->
    <view class="sk-card" style="border-top: 4rpx solid #f0f0f0;">
      <view class="sk-block sk-shimmer" style="width: 140rpx; height: 40rpx; border-radius: 8rpx; margin-bottom: 16rpx;"></view>
      <view class="sk-block sk-shimmer" style="width: 100%; height: 24rpx; border-radius: 6rpx; margin-bottom: 10rpx;"></view>
      <view class="sk-block sk-shimmer" style="width: 85%; height: 24rpx; border-radius: 6rpx;"></view>
    </view>
    <!-- 股票卡片骨架 -->
    <view class="sk-card" wx:for="{{2}}" wx:key="*this">
      <view class="sk-row" style="margin-bottom: 16rpx;">
        <view class="sk-col">
          <view class="sk-block sk-shimmer" style="width: 140rpx; height: 36rpx; border-radius: 8rpx;"></view>
          <view class="sk-block sk-shimmer" style="width: 100rpx; height: 24rpx; border-radius: 6rpx; margin-top: 8rpx;"></view>
        </view>
        <view class="sk-block sk-shimmer" style="width: 100rpx; height: 40rpx; border-radius: 8rpx; margin-left: auto;"></view>
      </view>
      <view class="sk-block sk-shimmer" style="width: 100%; height: 80rpx; border-radius: 10rpx;"></view>
    </view>
  </block>

  <!-- 雷达页骨架 -->
  <block wx:elif="{{type === 'radar'}}">
    <!-- 红绿灯骨架 -->
    <view class="sk-card">
      <view class="sk-block sk-shimmer" style="width: 160rpx; height: 36rpx; border-radius: 8rpx; margin-bottom: 24rpx;"></view>
      <view class="sk-light-grid">
        <view class="sk-light-item" wx:for="{{7}}" wx:key="*this">
          <view class="sk-circle sk-shimmer" style="width: 28rpx; height: 28rpx;"></view>
          <view class="sk-block sk-shimmer" style="width: 120rpx; height: 24rpx; border-radius: 6rpx; margin-left: 12rpx;"></view>
        </view>
      </view>
    </view>
    <!-- 风险评分骨架 -->
    <view class="sk-card" style="text-align: center;">
      <view class="sk-block sk-shimmer" style="width: 160rpx; height: 36rpx; border-radius: 8rpx; margin-bottom: 32rpx;"></view>
      <view class="sk-block sk-shimmer" style="width: 200rpx; height: 200rpx; border-radius: 50%; margin: 0 auto 24rpx;"></view>
      <view class="sk-block sk-shimmer" style="width: 80%; height: 24rpx; border-radius: 6rpx; margin: 0 auto;"></view>
    </view>
    <!-- 监控阈值表骨架 -->
    <view class="sk-card">
      <view class="sk-block sk-shimmer" style="width: 160rpx; height: 36rpx; border-radius: 8rpx; margin-bottom: 16rpx;"></view>
      <view class="sk-table-row" wx:for="{{3}}" wx:key="*this">
        <view class="sk-block sk-shimmer" style="width: 40%; height: 28rpx; border-radius: 6rpx;"></view>
        <view class="sk-block sk-shimmer" style="width: 50%; height: 28rpx; border-radius: 6rpx;"></view>
      </view>
    </view>
    <!-- 风险预警骨架 -->
    <view class="sk-card">
      <view class="sk-block sk-shimmer" style="width: 120rpx; height: 36rpx; border-radius: 8rpx; margin-bottom: 16rpx;"></view>
      <view class="sk-alert-item" wx:for="{{2}}" wx:key="*this">
        <view class="sk-block sk-shimmer" style="width: 70%; height: 28rpx; border-radius: 6rpx; margin-bottom: 8rpx;"></view>
        <view class="sk-row" style="gap: 12rpx; margin-bottom: 8rpx;">
          <view class="sk-block sk-shimmer" style="width: 80rpx; height: 24rpx; border-radius: 12rpx;"></view>
          <view class="sk-block sk-shimmer" style="width: 80rpx; height: 24rpx; border-radius: 12rpx;"></view>
        </view>
        <view class="sk-block sk-shimmer" style="width: 90%; height: 24rpx; border-radius: 6rpx;"></view>
      </view>
    </view>
  </block>
</view>
