/* traffic-light 组件样式 v4.0 — 支持7-8项紧凑布局 */

.tl-grid {
  display: flex;
  flex-wrap: wrap;
  margin-top: 8rpx;
}

.tl-item {
  width: 50%;
  display: flex;
  align-items: center;
  padding: 14rpx 0;
  box-sizing: border-box;
}

.tl-item:nth-child(odd) {
  padding-right: 12rpx;
}

.tl-item:nth-child(even) {
  padding-left: 12rpx;
}

.tl-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  margin-right: 12rpx;
  flex-shrink: 0;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tl-dot-inner {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.8);
}

/* 绿灯 */
.tl-green {
  background: #27ae60;
  box-shadow: 0 0 12rpx rgba(39, 174, 96, 0.5);
  animation: breathGreen 2s ease-in-out infinite;
}

/* 黄灯 */
.tl-yellow {
  background: #f1c40f;
  box-shadow: 0 0 12rpx rgba(241, 196, 15, 0.5);
  animation: breathYellow 2s ease-in-out infinite;
}

/* 红灯 */
.tl-red {
  background: #e74c3c;
  box-shadow: 0 0 12rpx rgba(231, 76, 60, 0.5);
  animation: breathRed 1.5s ease-in-out infinite;
}

@keyframes breathGreen {
  0%, 100% { box-shadow: 0 0 8rpx rgba(39, 174, 96, 0.4); }
  50% { box-shadow: 0 0 20rpx rgba(39, 174, 96, 0.8); }
}

@keyframes breathYellow {
  0%, 100% { box-shadow: 0 0 8rpx rgba(241, 196, 15, 0.4); }
  50% { box-shadow: 0 0 20rpx rgba(241, 196, 15, 0.8); }
}

@keyframes breathRed {
  0%, 100% { box-shadow: 0 0 8rpx rgba(231, 76, 60, 0.4); }
  50% { box-shadow: 0 0 24rpx rgba(231, 76, 60, 0.9); }
}

.tl-info {
  flex: 1;
  min-width: 0;
}

.tl-name {
  font-size: 24rpx;
  color: #555;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.tl-value {
  font-size: 22rpx;
  color: #999;
  margin-top: 2rpx;
}
