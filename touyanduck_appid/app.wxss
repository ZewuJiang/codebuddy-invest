/* app.wxss — 全局样式（投研鸭 v2.0） */
/* 升级版：增强间距系统、字体层级、阴影体系、标签扩展 */

/* ========== 基础重置 ========== */
page {
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', 'PingFang SC', 'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  color: #333333;
  background-color: #f5f6fa;
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
}

/* ========== 字体层级体系 ========== */
/* 特大标题 */
.text-xl {
  font-size: 36rpx;
  font-weight: 700;
}

/* 标题 */
.text-lg {
  font-size: 32rpx;
  font-weight: 600;
}

/* 正文 */
.text-md {
  font-size: 28rpx;
  font-weight: 400;
}

/* 辅助文字 */
.text-sm {
  font-size: 24rpx;
  color: #999;
}

/* 最小文字 */
.text-xs {
  font-size: 22rpx;
  color: #bbb;
}

/* ========== 间距体系（8rpx 为基础单位） ========== */
.mt-8 { margin-top: 8rpx; }
.mt-16 { margin-top: 16rpx; }
.mt-24 { margin-top: 24rpx; }
.mt-32 { margin-top: 32rpx; }
.mt-48 { margin-top: 48rpx; }
.mb-8 { margin-bottom: 8rpx; }
.mb-16 { margin-bottom: 16rpx; }
.mb-24 { margin-bottom: 24rpx; }
.p-16 { padding: 16rpx; }
.p-24 { padding: 24rpx; }
.p-32 { padding: 32rpx; }

/* ========== 颜色变量（涨跌/状态） ========== */
/* 涨/正面 = 红色 */
.color-up {
  color: #e74c3c;
}

/* 跌/负面 = 绿色 */
.color-down {
  color: #27ae60;
}

/* 持平/中性 = 灰色 */
.color-flat {
  color: #999999;
}

/* 主题强调色 = 鸭黄色 */
.color-primary {
  color: #FFB800;
}

/* ========== 通用卡片样式 ========== */
.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin: 16rpx 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.06);
  transition: box-shadow 0.2s ease;
}

/* 卡片 Hover 效果（可选） */
.card-hover {
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.1);
}

/* ========== 通用标题 ========== */
.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a2e;
  margin-bottom: 16rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #FFB800;
}

/* 副标题 */
.section-subtitle {
  font-size: 26rpx;
  color: #888;
  margin-bottom: 12rpx;
}

/* ========== 标签样式体系 ========== */
.tag {
  display: inline-block;
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  margin-right: 8rpx;
  margin-bottom: 4rpx;
  font-weight: 500;
}

/* 买入/涨/危险 */
.tag-red {
  background: rgba(231, 76, 60, 0.1);
  color: #e74c3c;
}

/* 看涨/偏多 */
.tag-orange {
  background: rgba(243, 156, 18, 0.12);
  color: #e67e22;
}

/* 观望/中性/黄灯 */
.tag-yellow {
  background: rgba(255, 184, 0, 0.15);
  color: #e6a600;
}

/* 看跌/偏空 */
.tag-blue {
  background: rgba(52, 152, 219, 0.1);
  color: #2980b9;
}

/* 卖出/跌/安全 */
.tag-green {
  background: rgba(39, 174, 96, 0.1);
  color: #27ae60;
}

/* 灰色/不重要 */
.tag-gray {
  background: rgba(153, 153, 153, 0.1);
  color: #999999;
}

/* ========== 分割线 ========== */
.divider {
  height: 1rpx;
  background: #eeeeee;
  margin: 20rpx 0;
}

.divider-dashed {
  height: 0;
  border-top: 1rpx dashed #eee;
  margin: 16rpx 0;
}

/* ========== 安全区域底部留白 ========== */
.safe-bottom {
  padding-bottom: calc(env(safe-area-inset-bottom) + 20rpx);
}

/* ========== Flex 工具类 ========== */
.flex-row {
  display: flex;
  align-items: center;
}

.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-1 {
  flex: 1;
}

.flex-shrink-0 {
  flex-shrink: 0;
}

/* ========== 空状态 ========== */
.empty-state {
  text-align: center;
  padding: 80rpx 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* ========== 页面淡入动画 ========== */
.page-fade-in {
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* ========== 数据截止时间（全局） ========== */
.data-footer {
  text-align: center;
  padding: 24rpx 32rpx 16rpx;
}

.footer-text {
  font-size: 20rpx;
  color: #bbb;
}
