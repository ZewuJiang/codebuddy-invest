/* mini-chart 组件样式 */
.mini-chart-wrap {
  display: inline-block;
  flex-shrink: 0;
  position: relative;
}

.mini-chart-canvas {
  display: block;
}

.mini-chart-empty {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx dashed #e0e0e0;
  border-radius: 6rpx;
  box-sizing: border-box;
}

.empty-text {
  font-size: 18rpx;
  color: #c0c0c0;
  letter-spacing: 1rpx;
}
