<!--pages/watchlist/watchlist.wxml-->
<!-- 标的页 v4.0：展开/收起 + 7板块 -->

<skeleton type="watchlist" loading="{{loading}}" />

<view class="page-container safe-bottom page-fade-in" wx:if="{{!loading}}">
  <!-- 板块切换 -->
  <view class="sector-tabs">
    <scroll-view scroll-x class="sector-scroll">
      <view class="sector-item {{activeSector === item.id ? 'sector-active' : ''}}" 
            wx:for="{{sectors}}" wx:key="id" 
            bindtap="switchSector" data-id="{{item.id}}">
        {{item.name}}
      </view>
    </scroll-view>
  </view>

  <!-- 当前板块概览 -->
  <view class="sector-content {{switching ? 'content-fade-out' : 'content-fade-in'}}">
    <view class="sector-overview-card {{animateReady ? 'overview-show' : ''}}" wx:if="{{currentSector}}">
      <view class="sector-header">
        <view class="sector-title">{{currentSector.name}}</view>
        <view class="tag {{currentSector.trendTagClass}}">{{currentSector.trendLabel}}</view>
      </view>
      <view class="sector-desc">{{currentSector.summary}}</view>
      <view class="sector-count">共 {{stocks.length}} 只标的 · 点击卡片展开详情</view>
    </view>

    <!-- 股票列表（展开/收起态） -->
    <stock-card 
      wx:for="{{stocks}}" 
      wx:key="symbol" 
      stock="{{item}}" 
      showDetail="{{true}}"
      animDelay="{{index * 100}}" />

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{stocks.length === 0}}">
      <view class="empty-icon">🦆</view>
      <view class="empty-text">暂无该板块的标的数据</view>
    </view>
  </view>

  <!-- 数据更新时间 -->
  <view class="data-footer" wx:if="{{dataTime}}">
    <text class="footer-text">更新时间 · {{dataTime}}</text>
  </view>
</view>
