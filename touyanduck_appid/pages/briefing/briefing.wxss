/* pages/briefing/briefing.wxss */
/* 简报页样式 v7.0 — 三段式精简架构：发生了什么 / 该怎么办 / 风险底线 */

.page-container {
  padding-bottom: 20rpx;
}

/* ========== ① 今日结论 + 重点事件（合并卡片）========== */
.combined-event-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin: 0 24rpx 16rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.06);
}

/* 合并卡片内的分隔线 */
.combined-divider {
  height: 1rpx;
  background: linear-gradient(90deg, transparent 0%, #f0f0f0 15%, #f0f0f0 85%, transparent 100%);
  margin: 18rpx 0 16rpx;
}

/* 通用卡片标题（今日结论、今日重点事件、全球资产反应 共用） */
.card-title-bar {
  font-size: 22rpx;
  font-weight: 600;
  color: #e67e22;
  letter-spacing: 1rpx;
  display: block;
  margin-bottom: 12rpx;
}

.takeaway-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  line-height: 1.7;
}

.takeaway-highlight {
  color: #e74c3c;
  font-weight: 700;
}

/* ========== §1 核心事件链（在合并卡片内使用）========== */
.event-chain {
  padding-left: 8rpx;
}

.chain-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 20rpx;
  position: relative;
}

.chain-item:last-child {
  margin-bottom: 0;
}

.chain-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #FFB800;
  flex-shrink: 0;
  margin-top: 12rpx;
  margin-right: 14rpx;
}

.chain-body {
  flex: 1;
  min-width: 0;
}

.chain-title {
  display: block;
  font-size: 27rpx;
  font-weight: 700;
  color: #1a1a2e;
  line-height: 1.5;
  margin-bottom: 4rpx;
}

.chain-brief {
  display: block;
  font-size: 23rpx;
  color: #888;
  line-height: 1.6;
  margin-bottom: 6rpx;
}

.chain-link-row {
  display: flex;
  align-items: center;
  margin-top: 2rpx;
}

.chain-link-tappable {
  cursor: pointer;
  border-radius: 6rpx;
  transition: opacity 0.15s ease;
}

.chain-link-tappable:active {
  opacity: 0.5;
}

.chain-link-icon {
  font-size: 20rpx;
  margin-right: 6rpx;
}

.chain-link-source {
  font-size: 21rpx;
  color: #2980b9;
  font-weight: 500;
}

.chain-link-no-url {
  color: #bbb;
  text-decoration: none;
  cursor: default;
  pointer-events: none;
}

.chain-link-arrow {
  font-size: 20rpx;
  color: #2980b9;
  margin-left: 4rpx;
}

/* ========== §1 全球资产反应 ========== */
.reaction-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin: 0 24rpx 16rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.06);
}

.reaction-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

/* reaction-header 内的 card-title-bar 不要额外 margin-bottom */
.reaction-header .card-title-bar {
  margin-bottom: 0;
}

.reaction-link {
  font-size: 22rpx;
  color: #FFB800;
  font-weight: 500;
}

.reaction-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 0;
}

.reaction-item {
  width: 33.33%;
  box-sizing: border-box;
  padding: 12rpx 8rpx;
  text-align: center;
  border-bottom: 1rpx solid #f5f5f5;
}

.reaction-item:nth-last-child(-n+3) {
  border-bottom: none;
}

.reaction-name {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 6rpx;
}

.reaction-value {
  font-size: 28rpx;
  font-weight: 700;
}

.reaction-note {
  font-size: 19rpx;
  color: #bbb;
  line-height: 1.4;
  margin-top: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  padding: 0 2rpx;
}

.reaction-up {
  color: #e74c3c;
}

.reaction-down {
  color: #27ae60;
}

.reaction-flat {
  color: #999;
}

/* ========== §1 三大核心判断 ========== */
.judgment-list {
  margin-top: 4rpx;
}

.judgment-item {
  margin-bottom: 24rpx;
  padding: 20rpx;
  background: #f8f9fc;
  border-radius: 12rpx;
}

.judgment-item:last-child {
  margin-bottom: 0;
}

.judgment-header {
  display: flex;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.judgment-num {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FFB800, #FF8C00);
  color: #fff;
  font-size: 20rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 12rpx;
  margin-top: 2rpx;
}

.judgment-title {
  font-size: 25rpx;
  font-weight: 600;
  color: #1a1a2e;
  line-height: 1.5;
  flex: 1;
}

.judgment-confidence {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
  padding: 0 4rpx;
}

.confidence-label {
  font-size: 22rpx;
  color: #999;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.confidence-bar {
  flex: 1;
  height: 12rpx;
  background: #eee;
  border-radius: 6rpx;
  overflow: hidden;
  margin-right: 12rpx;
}

.confidence-fill {
  height: 100%;
  border-radius: 6rpx;
  background: linear-gradient(90deg, #FFB800, #FF8C00);
  transition: width 1s cubic-bezier(0.4, 0, 0.2, 1);
}

.confidence-value {
  font-size: 24rpx;
  font-weight: 700;
  color: #FFB800;
  flex-shrink: 0;
  min-width: 60rpx;
  text-align: right;
}

.judgment-logic {
  display: flex;
  align-items: flex-start;
  padding: 0 4rpx;
}


.logic-text {
  font-size: 24rpx;
  color: #888;
  line-height: 1.6;
}

/* ========== §1 行动建议 ========== */
.action-group {
  margin-bottom: 20rpx;
}

.action-group:last-child {
  margin-bottom: 0;
}

.action-group-label {
  font-size: 24rpx;
  font-weight: 600;
  color: #666;
  margin-bottom: 12rpx;
}

.action-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 12rpx;
  padding: 14rpx 16rpx;
  background: #f8f9fc;
  border-radius: 10rpx;
}

.action-item:last-child {
  margin-bottom: 0;
}

.action-body {
  flex: 1;
  min-width: 0;
}

.action-content {
  font-size: 26rpx;
  color: #333;
  line-height: 1.6;
}

.action-reason {
  font-size: 22rpx;
  color: #999;
  line-height: 1.5;
  margin-top: 5rpx;
}

/* ========== ③ 聪明钱建议 ========== */
/* 操作提示区域（可选，置顶，无子标题直接渲染） */
.action-hint-section {
  margin-bottom: 16rpx;
}

/* 聪明钱动向子区域 */
.sm-section-header {
  border-top: 1rpx solid #f0f0f0;
  padding-top: 16rpx;
  margin-bottom: 12rpx;
}

.sm-section-title {
  font-size: 24rpx;
  font-weight: 600;
  color: #666;
}

/* 重点持仓 */
.holdings-section {
  margin-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
  padding-top: 16rpx;
}

.holdings-header {
  margin-bottom: 12rpx;
}

.holdings-title {
  font-size: 24rpx;
  font-weight: 600;
  color: #666;
}

.holdings-list {
  margin-top: 4rpx;
}

.holdings-item {
  display: flex;
  align-items: flex-start;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.holdings-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.holdings-name {
  font-size: 24rpx;
  font-weight: 600;
  color: #1a1a2e;
  flex-shrink: 0;
  margin-right: 16rpx;
  min-width: 120rpx;
}

.holdings-detail {
  font-size: 23rpx;
  color: #888;
  line-height: 1.6;
  flex: 1;
}

/* ========== ④ 风险与情绪（合并卡片中的情绪仪表盘）========== */
.sentiment-bar {
  display: flex;
  align-items: center;
  margin-top: 8rpx;
}

.sentiment-label {
  font-size: 22rpx;
  color: #999;
  flex-shrink: 0;
}

.sentiment-track {
  flex: 1;
  height: 14rpx;
  background: #eee;
  border-radius: 7rpx;
  margin: 0 16rpx;
  overflow: visible;
  position: relative;
}

.sentiment-fill {
  height: 100%;
  border-radius: 7rpx;
  background: linear-gradient(90deg, #27ae60, #f1c40f 50%, #e74c3c);
  transition: width 1s cubic-bezier(0.4, 0, 0.2, 1);
}

.sentiment-pointer {
  position: absolute;
  top: -9rpx;
  transform: translateX(-50%);
  transition: left 1s cubic-bezier(0.4, 0, 0.2, 1);
}

.sentiment-pointer-dot {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  background: #fff;
  border: 4rpx solid #FFB800;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.15);
}

.sentiment-info {
  text-align: center;
  margin-top: 16rpx;
}

.sentiment-score-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.sentiment-number {
  font-size: 48rpx;
  font-weight: 700;
  color: #FFB800;
}

.sentiment-tag {
  font-size: 24rpx;
  color: #999;
  background: rgba(255, 184, 0, 0.1);
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
}

/* ========== §4 聪明钱速览（合并入决策建议卡片）========== */
.smart-money-list {
  margin-top: 4rpx;
}

.smart-money-item {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.smart-money-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.sm-left {
  display: flex;
  align-items: center;
  flex-shrink: 0;
  margin-right: 16rpx;
}

.sm-signal {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  margin-right: 10rpx;
}

.sm-bullish {
  background: #e74c3c;
  box-shadow: 0 0 6rpx rgba(231, 76, 60, 0.4);
}

.sm-bearish {
  background: #27ae60;
  box-shadow: 0 0 6rpx rgba(39, 174, 96, 0.4);
}

.sm-neutral {
  background: #f1c40f;
  box-shadow: 0 0 6rpx rgba(241, 196, 15, 0.4);
}

.sm-source {
  font-size: 26rpx;
  font-weight: 600;
  color: #1a1a2e;
  white-space: nowrap;
}

.sm-action {
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
  text-align: right;
  flex: 1;
}

.sm-more {
  text-align: center;
  font-size: 24rpx;
  color: #FFB800;
  padding: 16rpx 0 4rpx;
  font-weight: 500;
}

/* ========== ④ 风险与情绪（合并卡片）========== */
.risk-sent-card {
  border-left: 6rpx solid #e74c3c;
}

/* 风险点列表（在合并卡片内）*/
.risk-list-section {
  margin-top: 20rpx;
  border-top: 1rpx solid #fce4e4;
  padding-top: 16rpx;
}

.risk-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.risk-item:last-child {
  margin-bottom: 0;
}

.risk-dot {
  color: #e74c3c;
  font-size: 28rpx;
  font-weight: bold;
  margin-right: 12rpx;
  flex-shrink: 0;
  line-height: 1.7;
}

.risk-item-text {
  font-size: 24rpx;
  color: #666;
  line-height: 1.7;
  flex: 1;
}

/* 兼容旧格式 */
.risk-text {
  font-size: 24rpx;
  color: #666;
  line-height: 1.7;
}

/* ========== v1.3 时间状态栏 ========== */
.ts-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: rgba(26, 26, 46, 0.88);
  padding: 16rpx 32rpx;
  margin: 0 0 16rpx;
}

.ts-item {
  flex: 1;
  text-align: center;
}

.ts-divider {
  width: 1rpx;
  height: 48rpx;
  background: rgba(255, 255, 255, 0.15);
  flex-shrink: 0;
}

.ts-time {
  font-size: 32rpx;
  font-weight: 700;
  color: #FFB800;
  letter-spacing: 1rpx;
}

.ts-label {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-top: 4rpx;
}

.ts-label-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  margin-top: 4rpx;
}

.ts-market-tag {
  font-size: 18rpx;
  padding: 2rpx 10rpx;
  border-radius: 8rpx;
  font-weight: 500;
}

.ts-market-open {
  background: rgba(39, 174, 96, 0.25);
  color: #27ae60;
}

.ts-market-closed {
  background: rgba(255, 255, 255, 0.1);
  color: rgba(255, 255, 255, 0.4);
}

/* ========== v1.4 语音播报按钮（嵌入时间状态栏）========== */
.ts-voice-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  transition: background 0.2s ease;
  flex-shrink: 0;
}

.ts-voice-btn:active {
  background: rgba(255, 184, 0, 0.2);
}

.ts-voice-playing {
  background: rgba(255, 184, 0, 0.15);
}

.ts-voice-icon {
  font-size: 36rpx;
  line-height: 1;
}

.ts-voice-label {
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-top: 4rpx;
}

.ts-voice-playing .ts-voice-label {
  color: #FFB800;
}

/* 加载动画（三个跳动圆点）*/
.ts-voice-loading {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  height: 36rpx;
}

.ts-voice-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #FFB800;
  animation: voiceDotBounce 0.8s ease-in-out infinite;
}

.ts-dot-1 { animation-delay: 0s; }
.ts-dot-2 { animation-delay: 0.15s; }
.ts-dot-3 { animation-delay: 0.3s; }

@keyframes voiceDotBounce {
  0%, 80%, 100% { transform: scale(0.6); opacity: 0.4; }
  40% { transform: scale(1); opacity: 1; }
}

/* ========== v1.3 判断扩展信息 ========== */
.jx-extension {
  margin-top: 8rpx;
}

.jx-divider {
  height: 1rpx;
  background: linear-gradient(90deg, transparent 0%, #e8e8e8 15%, #e8e8e8 85%, transparent 100%);
  margin: 14rpx 4rpx;
}

.jx-tags {
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
  margin-bottom: 10rpx;
}

.jx-tag {
  font-size: 20rpx;
  padding: 4rpx 14rpx;
  border-radius: 12rpx;
  font-weight: 500;
}

.jx-prob-high {
  background: rgba(41, 128, 185, 0.12);
  color: #2980b9;
}

.jx-prob-medium {
  background: rgba(241, 196, 15, 0.12);
  color: #d4a017;
}

.jx-prob-low {
  background: rgba(153, 153, 153, 0.12);
  color: #999;
}

.jx-trend-up {
  background: rgba(39, 174, 96, 0.12);
  color: #27ae60;
}

.jx-trend-down {
  background: rgba(231, 76, 60, 0.12);
  color: #e74c3c;
}

.jx-trend-stable {
  background: rgba(153, 153, 153, 0.12);
  color: #999;
}

.jx-actor-row {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.jx-actor-icon {
  font-size: 22rpx;
  margin-right: 6rpx;
}

.jx-actor-label {
  font-size: 20rpx;
  color: #999;
  margin-right: 8rpx;
}

.jx-actor-name {
  font-size: 22rpx;
  color: #555;
  font-weight: 500;
}

/* ========== v1.3.1 参考源手风琴 ========== */
.jx-ref-section {
  margin-top: 6rpx;
}

.jx-ref-header {
  display: flex;
  align-items: center;
  padding: 10rpx 0;
}

.jx-ref-icon {
  font-size: 22rpx;
  margin-right: 6rpx;
}

.jx-ref-label {
  font-size: 18rpx;
  color: #bbb;
  font-weight: 600;
  letter-spacing: 1rpx;
  margin-right: 8rpx;
}

.jx-ref-names {
  font-size: 20rpx;
  color: #888;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.jx-ref-count {
  font-size: 18rpx;
  color: #FFB800;
  margin-left: 6rpx;
  flex-shrink: 0;
}

.jx-ref-arrow {
  font-size: 28rpx;
  color: #ccc;
  margin-left: 4rpx;
  transition: transform 0.3s ease;
  transform: rotate(90deg);
  flex-shrink: 0;
}

.jx-arrow-up {
  transform: rotate(-90deg);
}

/* 展开面板（手风琴动画） */
.jx-ref-panel {
  overflow: hidden;
  transition: max-height 0.35s ease, opacity 0.3s ease;
}

.jx-panel-show {
  max-height: 800rpx;
  opacity: 1;
  margin-top: 8rpx;
}

.jx-panel-hide {
  max-height: 0;
  opacity: 0;
}

/* 每条来源详情 */
.jx-ref-detail {
  padding: 14rpx 0 14rpx 8rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.jx-ref-detail:last-child {
  border-bottom: none;
}

.jx-ref-detail-header {
  display: flex;
  align-items: center;
}

.jx-ref-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #FFB800;
  margin-right: 10rpx;
  flex-shrink: 0;
}

.jx-ref-detail-name {
  font-size: 24rpx;
  font-weight: 600;
  color: #1a1a2e;
}

.jx-ref-detail-summary {
  font-size: 22rpx;
  color: #888;
  line-height: 1.6;
  margin-top: 6rpx;
  padding-left: 18rpx;
}

.jx-ref-detail-link {
  display: flex;
  align-items: center;
  margin-top: 6rpx;
  padding-left: 18rpx;
}

/* 可点击态：hover/active 反馈 */
.jx-ref-tappable {
  cursor: pointer;
  border-radius: 6rpx;
  transition: opacity 0.15s ease;
}

.jx-ref-tappable:active {
  opacity: 0.5;
}

.jx-ref-domain {
  font-size: 20rpx;
  color: #2980b9;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 500rpx;
}

.jx-ref-link-icon {
  font-size: 20rpx;
  color: #2980b9;
  margin-left: 4rpx;
  flex-shrink: 0;
}

/* data-footer / footer-text 已统一到 app.wxss */

/* ========== 入场动画 ========== */
.stagger-item {
  opacity: 0;
  transform: translateY(16rpx);
}

.stagger-show {
  animation: slideUp 0.4s ease forwards;
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(16rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
