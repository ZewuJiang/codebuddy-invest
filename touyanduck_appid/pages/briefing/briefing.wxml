<!--pages/briefing/briefing.wxml-->
<!-- 简报页 v6.0：takeaway + 今日重点事件(chain对象化) + 全球资产反应(note) + 三大核心判断 + 行动建议(reason) -->

<!-- 骨架屏 -->
<skeleton type="briefing" loading="{{loading}}" rows="{{4}}" />

<!-- 正式内容 -->
<view class="page-container safe-bottom page-fade-in" wx:if="{{!loading}}">

  <!-- v1.3 时间状态栏 -->
  <view class="ts-bar" wx:if="{{timeStatus}}">
    <view class="ts-item">
      <view class="ts-time">{{timeStatus.bjt}}</view>
      <view class="ts-label">{{timeStatus.bjtLabel}}</view>
    </view>
    <view class="ts-divider"></view>
    <view class="ts-item">
      <view class="ts-time">{{timeStatus.est}}</view>
      <view class="ts-label-row">
        <text class="ts-label">{{timeStatus.estLabel}}</text>
        <text class="ts-market-tag {{marketStatusOpen ? 'ts-market-open' : 'ts-market-closed'}}">{{marketStatus}}</text>
      </view>
    </view>
    <view class="ts-divider"></view>
    <view class="ts-item">
      <view class="ts-time">{{dataFreshness || '--'}}</view>
      <view class="ts-label">数据更新</view>
    </view>
  </view>

  <!-- 今日核心结论 TAKEAWAY -->
  <view class="takeaway-card stagger-item {{animateReady ? 'stagger-show' : ''}}" wx:if="{{takeaway}}" style="animation-delay: 0ms">
    <view class="card-title-bar">📌 今日结论</view>
    <view class="takeaway-text">
      <text wx:for="{{takeawaySegments}}" wx:key="index" class="{{item.highlight ? 'takeaway-highlight' : ''}}">{{item.text}}</text>
    </view>
  </view>

  <!-- §1 核心事件卡片 -->
  <view class="event-card stagger-item {{animateReady ? 'stagger-show' : ''}}" wx:if="{{coreEvent}}" style="animation-delay: 60ms">
    <view class="card-title-bar">🚨 重点事件</view>
    <view class="event-title">{{coreEvent.title}}</view>
    <view class="event-chain">
      <view class="chain-item" wx:for="{{coreEvent.chain}}" wx:key="index">
        <view class="chain-dot"></view>
        <view class="chain-body">
          <text class="chain-title">{{item.title}}</text>
          <text class="chain-brief" wx:if="{{item.brief}}">{{item.brief}}</text>
          <!-- 来源链接行：有 url 才渲染可点击，否则只显示来源名 -->
          <view wx:if="{{item.url}}" class="chain-link-row chain-link-tappable"
                bindtap="onChainLinkTap"
                data-url="{{item.url}}"
                data-name="{{item.source || '原文'}}">
            <text class="chain-link-icon">📎</text>
            <text class="chain-link-source">{{item.source || '原文'}}</text>
            <text class="chain-link-arrow">↗</text>
          </view>
          <view wx:elif="{{item.source}}" class="chain-link-row">
            <text class="chain-link-icon">📎</text>
            <text class="chain-link-source chain-link-no-url">{{item.source}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- §1 全球资产反应 -->
  <view class="reaction-card stagger-item {{animateReady ? 'stagger-show' : ''}}" style="animation-delay: 80ms" bindtap="onReactionTap">
    <view class="reaction-header">
      <text class="card-title-bar">📊 全球资产反应</text>
      <text class="reaction-link">查看市场详情 ›</text>
    </view>
    <view class="reaction-grid">
      <view class="reaction-item" wx:for="{{globalReaction}}" wx:key="name">
        <view class="reaction-name">{{item.name}}</view>
        <view class="reaction-value reaction-{{item.direction}}">{{item.value}}</view>
        <view class="reaction-note" wx:if="{{item.note}}">{{item.note}}</view>
      </view>
    </view>
  </view>

  <!-- §1 三大核心判断 -->
  <section-card title="🎯 核心判断" collapsible="{{true}}" expanded="{{true}}">
    <view class="judgment-list">
      <view class="judgment-item stagger-item {{animateReady ? 'stagger-show' : ''}}" 
            wx:for="{{coreJudgments}}" wx:key="index"
            style="animation-delay: {{(index + 2) * 80}}ms">
        <view class="judgment-header">
          <view class="judgment-num">{{index + 1}}</view>
          <view class="judgment-title">{{item.title}}</view>
        </view>
        <view class="judgment-confidence">
          <view class="confidence-label">置信度</view>
          <view class="confidence-bar">
            <view class="confidence-fill" style="width: {{animateReady ? item.confidence : 0}}%"></view>
          </view>
          <view class="confidence-value">{{item.confidence}}%</view>
        </view>
        <view class="judgment-logic">
          <text class="logic-text">{{item.logic}}</text>
        </view>
        <!-- v1.3 判断扩展信息 -->
        <view class="jx-extension" wx:if="{{item.hasExtension}}">
          <view class="jx-divider"></view>
          <!-- 概率+趋势标签组 -->
          <view class="jx-tags" wx:if="{{item.probability || item.trend}}">
            <view class="jx-tag {{item.probClass}}" wx:if="{{item.probability}}">{{item.probability}}</view>
            <view class="jx-tag {{item.trendClass}}" wx:if="{{item.trend}}">{{item.trendArrow}} {{item.trend}}</view>
          </view>
          <!-- 关键决策者 -->
          <view class="jx-actor-row" wx:if="{{item.keyActor}}">
            <text class="jx-actor-icon">👤</text>
            <text class="jx-actor-label">关键决策</text>
            <text class="jx-actor-name">{{item.keyActor}}</text>
          </view>
          <!-- v1.3.1 参考源（可点击展开手风琴） -->
          <view class="jx-ref-section" wx:if="{{item.references.length}}">
            <view class="jx-ref-header" bindtap="onRefToggle" data-j-idx="{{index}}">
              <text class="jx-ref-icon">📎</text>
              <text class="jx-ref-label">REFERENCE</text>
              <text class="jx-ref-names">{{item.refNames}}</text>
              <text class="jx-ref-count">[{{item.refCount}}]</text>
              <text class="jx-ref-arrow {{expandedRefs[index] ? 'jx-arrow-up' : ''}}">›</text>
            </view>
            <!-- 展开面板 -->
            <view class="jx-ref-panel {{expandedRefs[index] ? 'jx-panel-show' : 'jx-panel-hide'}}">
              <view class="jx-ref-detail" wx:for="{{item.references}}" wx:for-item="ref" wx:key="name" wx:for-index="rIdx">
                <view class="jx-ref-detail-header">
                  <view class="jx-ref-dot"></view>
                  <text class="jx-ref-detail-name">{{ref.name}}</text>
                </view>
                <view class="jx-ref-detail-summary" wx:if="{{ref.summary}}">{{ref.summary}}</view>
                <view class="jx-ref-detail-link jx-ref-tappable" wx:if="{{ref.url}}"
                      bindtap="onRefLinkTap"
                      data-url="{{ref.url}}"
                      data-name="{{ref.name}}">
                  <text class="jx-ref-domain">{{ref.url}}</text>
                  <text class="jx-ref-link-icon">↗</text>
                </view>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>
  </section-card>

  <!-- §1 行动建议 -->
  <section-card title="⚡ 行动建议" collapsible="{{true}}" expanded="{{true}}">
    <!-- 今日 -->
    <view class="action-group" wx:if="{{todayActions.length}}">
      <view class="action-group-label">☀️ 今日</view>
      <view class="action-item stagger-item {{animateReady ? 'stagger-show' : ''}}" 
            wx:for="{{todayActions}}" wx:key="index"
            style="animation-delay: {{(index + 5) * 80}}ms">
        <view class="tag {{item.tagClass}}">{{item.label}}</view>
        <view class="action-body">
          <view class="action-content">{{item.content}}</view>
          <view class="action-reason" wx:if="{{item.reason}}">{{item.reason}}</view>
        </view>
      </view>
    </view>
    <!-- 本周 -->
    <view class="action-group" wx:if="{{weekActions.length}}">
      <view class="action-group-label">📋 本周</view>
      <view class="action-item stagger-item {{animateReady ? 'stagger-show' : ''}}" 
            wx:for="{{weekActions}}" wx:key="index"
            style="animation-delay: {{(index + 7) * 80}}ms">
        <view class="tag {{item.tagClass}}">{{item.label}}</view>
        <view class="action-body">
          <view class="action-content">{{item.content}}</view>
          <view class="action-reason" wx:if="{{item.reason}}">{{item.reason}}</view>
        </view>
      </view>
    </view>
  </section-card>

  <!-- §2 市场情绪仪表盘 -->
  <section-card title="🌡️ 市场情绪" collapsible="{{true}}" expanded="{{true}}">
    <view class="sentiment-bar">
      <view class="sentiment-label">恐惧</view>
      <view class="sentiment-track">
        <view class="sentiment-fill" style="width: {{animateReady ? sentimentScore : 0}}%"></view>
        <view class="sentiment-pointer" style="left: {{animateReady ? sentimentScore : 0}}%">
          <view class="sentiment-pointer-dot"></view>
        </view>
      </view>
      <view class="sentiment-label">贪婪</view>
    </view>
    <view class="sentiment-info">
      <view class="sentiment-score-row">
        <text class="sentiment-number">{{displaySentiment}}</text>
        <text class="sentiment-tag">{{sentimentLabel}}</text>
      </view>
    </view>
    <view class="market-summary-list" wx:if="{{marketSummaryPoints.length}}">
      <view class="ms-item" wx:for="{{marketSummaryPoints}}" wx:key="index">
        <view class="ms-dot"></view>
        <text class="ms-text">{{item}}</text>
      </view>
    </view>
  </section-card>

  <!-- §4 聪明钱速览 -->
  <section-card title="🧠 聪明钱动向" collapsible="{{true}}" expanded="{{true}}" wx:if="{{smartMoney.length}}">
    <view class="smart-money-list">
      <view class="smart-money-item stagger-item {{animateReady ? 'stagger-show' : ''}}" 
            wx:for="{{smartMoney}}" wx:key="index"
            style="animation-delay: {{(index + 9) * 80}}ms">
        <view class="sm-left">
          <view class="sm-signal sm-{{item.signal}}"></view>
          <view class="sm-source">{{item.source}}</view>
        </view>
        <view class="sm-action">{{item.action}}</view>
      </view>
    </view>
    <view class="sm-more" bindtap="onSmartMoneyTap">查看更多聪明钱动向 ›</view>
  </section-card>

  <!-- 风险提示 -->
  <section-card title="🛡️ 风险提示" extraClass="risk-card" borderColor="#e74c3c">
    <view class="risk-item" wx:for="{{riskPoints}}" wx:key="index">
      <text class="risk-dot">•</text>
      <text class="risk-item-text">{{item}}</text>
    </view>
    <!-- 兼容旧格式 -->
    <view class="risk-text" wx:if="{{!riskPoints.length && riskNote}}">{{riskNote}}</view>
  </section-card>

  <!-- 数据更新时间 -->
  <view class="data-footer" wx:if="{{dataTime}}">
    <text class="footer-text">更新时间 · {{dataTime}}</text>
  </view>

</view>
