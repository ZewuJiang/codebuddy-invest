/* pages/markets/markets.wxss */
/* 市场页样式 v4.0 — 5Tab + GICS热力图 + M7巨头 */

.page-container {
  padding-bottom: 20rpx;
}

/* ========== 顶部Tab ========== */
.tab-bar {
  display: flex;
  background: #ffffff;
  padding: 16rpx 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
  position: sticky;
  top: 0;
  z-index: 10;
  position: relative;
}

.tab-item {
  flex: 1;
  text-align: center;
  font-size: 26rpx;
  color: #999;
  padding: 12rpx 0;
  position: relative;
  transition: color 0.3s ease;
  z-index: 1;
}

.tab-active {
  color: #FFB800;
  font-weight: 600;
}

.tab-indicator {
  position: absolute;
  bottom: 6rpx;
  left: 24rpx;
  width: calc((100% - 48rpx) / 5);
  height: 4rpx;
  transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  display: flex;
  justify-content: center;
}

.tab-indicator::after {
  content: '';
  width: 36rpx;
  height: 4rpx;
  background: linear-gradient(90deg, #FFB800, #FF8C00);
  border-radius: 2rpx;
}

/* ========== Swiper ========== */
.market-swiper {
  width: 100%;
}

.market-scroll {
  height: 100%;
}

/* ========== Tab内容包裹（SelectorQuery量高用） ========== */
.tab-content-wrap {
  padding-bottom: 24rpx;
}

/* ========== 列表卡片 ========== */
.market-list-card {
  background: #ffffff;
  border-radius: 16rpx;
  margin: 16rpx 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.06);
  overflow: hidden;
}

.market-list-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
  transition: background 0.15s;
}

.market-list-item:last-child {
  border-bottom: none;
}

.market-list-item:active {
  background: #fafafa;
}

.ml-left {
  flex: 1;
  min-width: 0;
}

.ml-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a2e;
  margin-bottom: 4rpx;
}

.ml-price {
  font-size: 24rpx;
  color: #888;
}

.ml-center {
  flex-shrink: 0;
  margin: 0 16rpx;
  display: flex;
  align-items: center;
}

.ml-right {
  text-align: right;
  min-width: 110rpx;
  flex-shrink: 0;
}

.ml-change-badge {
  font-size: 28rpx;
  font-weight: 700;
}

.ml-label {
  font-size: 20rpx;
  color: #999;
  margin-top: 4rpx;
}

/* ========== 市场简评 ========== */
.market-comment {
  display: flex;
  align-items: flex-start;
  margin: 0 24rpx 16rpx;
  padding: 16rpx 20rpx;
  background: rgba(255, 184, 0, 0.06);
  border-radius: 12rpx;
  border: 1rpx solid rgba(255, 184, 0, 0.15);
  opacity: 0;
  transform: translateY(10rpx);
  transition: all 0.4s ease 0.3s;
}

.comment-show {
  opacity: 1;
  transform: translateY(0);
}

.comment-icon {
  margin-right: 10rpx;
  flex-shrink: 0;
}

.comment-text {
  font-size: 24rpx;
  color: #666;
  line-height: 1.6;
}

/* ========== M7巨头头部 ========== */
.m7-header {
  padding: 24rpx 32rpx 8rpx;
}

.m7-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a2e;
  display: block;
}

.m7-subtitle {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
  display: block;
}

/* ========== GICS板块热力图 ========== */
.gics-section {
  margin: 16rpx 24rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.06);
}

.gics-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a2e;
  margin-bottom: 16rpx;
  padding-left: 12rpx;
  border-left: 4rpx solid #FFB800;
}

.gics-grid {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.gics-item {
  display: flex;
  align-items: center;
  padding: 10rpx 0;
}

.gics-name {
  font-size: 24rpx;
  color: #555;
  width: 200rpx;
  flex-shrink: 0;
}

.gics-bar {
  flex: 1;
  height: 16rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  overflow: hidden;
  margin: 0 16rpx;
}

.gics-bar-fill {
  height: 100%;
  border-radius: 8rpx;
  transition: width 0.8s ease;
  max-width: 100%;
}

.bar-up {
  background: linear-gradient(90deg, rgba(231, 76, 60, 0.3), #e74c3c);
}

.bar-down {
  background: linear-gradient(90deg, rgba(39, 174, 96, 0.3), #27ae60);
}

.gics-change {
  font-size: 24rpx;
  font-weight: 600;
  min-width: 100rpx;
  text-align: right;
  flex-shrink: 0;
}

/* ========== 数据截止时间 ========== */
.data-footer {
  text-align: center;
  padding: 16rpx 32rpx;
}

.footer-text {
  font-size: 20rpx;
  color: #bbb;
}

/* ========== 入场动画 ========== */
.stagger-item {
  opacity: 0;
  transform: translateX(30rpx);
}

.stagger-show {
  animation: slideInRight 0.4s ease forwards;
}

@keyframes slideInRight {
  from {
    opacity: 0;
    transform: translateX(30rpx);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

/* ========== 竖版因果链 Insight ========== */
.insight-chain {
  margin: 0 24rpx 20rpx;
  background: rgba(255, 184, 0, 0.05);
  border-radius: 16rpx;
  border: 1rpx solid rgba(255, 184, 0, 0.18);
  padding: 20rpx 24rpx 16rpx;
  opacity: 0;
  transform: translateY(10rpx);
  transition: all 0.4s ease 0.3s;
}

.insight-chain.comment-show {
  opacity: 1;
  transform: translateY(0);
}

.chain-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.chain-icon {
  font-size: 26rpx;
  margin-right: 8rpx;
}

.chain-title {
  font-size: 24rpx;
  font-weight: 600;
  color: #B8860B;
  letter-spacing: 1rpx;
}

.chain-body {
  display: flex;
  flex-direction: column;
}

.chain-node {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
}

.chain-node-left {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 48rpx;
  flex-shrink: 0;
  margin-right: 16rpx;
}

.chain-dot {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: rgba(255, 184, 0, 0.12);
  border: 1rpx solid rgba(255, 184, 0, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  flex-shrink: 0;
}

.chain-line {
  width: 2rpx;
  flex: 1;
  min-height: 20rpx;
  background: linear-gradient(to bottom, rgba(255, 184, 0, 0.4), rgba(255, 184, 0, 0.1));
  margin: 4rpx 0;
}

.chain-node-right {
  flex: 1;
  padding-bottom: 24rpx;
  min-height: 44rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.chain-label {
  font-size: 20rpx;
  font-weight: 700;
  color: #FFB800;
  letter-spacing: 2rpx;
  margin-bottom: 6rpx;
  text-transform: uppercase;
}

.chain-text {
  font-size: 27rpx;
  color: #333;
  line-height: 1.65;
}

/* GICS 区域内的因果链无外边距 */
.gics-section .insight-chain {
  margin: 16rpx 0 0;
}
