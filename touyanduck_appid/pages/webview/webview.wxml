<!--pages/webview/webview.wxml-->

<!-- URL 无效时的提示界面 -->
<view class="invalid-wrap" wx:if="{{urlInvalid}}">
  <text class="invalid-icon">🔗</text>
  <text class="invalid-text">该链接暂不支持在小程序内打开</text>
  <text class="invalid-hint">请复制链接在浏览器中查看</text>
</view>

<!-- 正常 web-view -->
<web-view
  wx:if="{{!urlInvalid && url}}"
  src="{{url}}"
  bindload="onWebviewLoad"
  binderror="onWebviewError"
/>
