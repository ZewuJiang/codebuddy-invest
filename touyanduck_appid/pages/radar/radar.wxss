/* pages/radar/radar.wxss */
/* 雷达页样式 v6.3 — 聪明钱最优先：动向#1 + 持仓#2 + 风险判断#3 */

.page-container {
  padding-bottom: 20rpx;
}

/* ========================================
   #1 🧠 聪明钱动向
   ======================================== */

.sm-flat-list {
  margin-top: 4rpx;
}

.sm-flat-item {
  padding: 14rpx 0;
  border-bottom: 1rpx solid #f8f8f8;
}

.sm-flat-item:last-of-type {
  border-bottom: none;
}

.sm-flat-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.sm-flat-left {
  display: flex;
  align-items: center;
  flex-shrink: 0;
}

.sm-flat-name {
  font-size: 26rpx;
  font-weight: 700;
  color: #1a1a2e;
  margin-right: 8rpx;
}

.sm-tier-badge {
  font-size: 18rpx;
  background: rgba(255, 184, 0, 0.15);
  color: #FFB800;
  padding: 2rpx 8rpx;
  border-radius: 8rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.sm-flat-action {
  font-size: 24rpx;
  color: #555;
  line-height: 1.7;
}

.sm-fund-signal {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  margin-right: 8rpx;
  flex-shrink: 0;
}

.sm-bullish {
  background: #e74c3c;
  box-shadow: 0 0 6rpx rgba(231, 76, 60, 0.4);
}

.sm-bearish {
  background: #27ae60;
  box-shadow: 0 0 6rpx rgba(39, 174, 96, 0.4);
}

.sm-neutral {
  background: #f1c40f;
  box-shadow: 0 0 6rpx rgba(241, 196, 15, 0.4);
}

/* ========================================
   #2 💼 聪明钱持仓（默认折叠）
   ======================================== */

.holdings-module {
  margin-top: 4rpx;
}

.holdings-group {
  margin-bottom: 16rpx;
}

.holdings-group:last-child {
  margin-bottom: 0;
}

.holdings-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.holdings-header-left {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.holdings-manager {
  font-size: 28rpx;
  font-weight: 700;
  color: #1a1a2e;
}

.holdings-aum {
  font-size: 20rpx;
  color: #999;
}

.holdings-header-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.holdings-date {
  font-size: 20rpx;
  color: #bbb;
  background: #f8f8f8;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.holdings-arrow {
  font-size: 18rpx;
  color: #ccc;
}

.holdings-body {
  padding: 12rpx 0;
}

.holdings-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10rpx 0;
  border-bottom: 1rpx solid #fafafa;
}

.holdings-row:last-of-type {
  border-bottom: none;
}

.holdings-row-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: 1;
}

.holdings-rank {
  font-size: 22rpx;
  font-weight: 700;
  color: #ccc;
  width: 36rpx;
  text-align: center;
  flex-shrink: 0;
}

.holdings-stock-info {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.holdings-stock-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
}

.holdings-stock-symbol {
  font-size: 20rpx;
  color: #999;
}

.holdings-row-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}

.holdings-weight {
  font-size: 26rpx;
  font-weight: 700;
  color: #FFB800;
  min-width: 80rpx;
  text-align: right;
}

.holdings-change {
  font-size: 20rpx;
  color: #999;
  background: #f5f5f5;
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
}

.holdings-footnote {
  padding: 10rpx 0 4rpx;
  border-top: 1rpx dashed #f0f0f0;
  margin-top: 4rpx;
}

.holdings-footnote-text {
  font-size: 20rpx;
  color: #bbb;
  line-height: 1.6;
}

/* ========================================
   #3 🛡️ 风险判断
   ======================================== */

.safety-card {
  padding: 4rpx 0;
}

.risk-verdict {
  background: linear-gradient(135deg, rgba(231, 76, 60, 0.06), rgba(255, 184, 0, 0.04));
  border-left: 4rpx solid #e74c3c;
  border-radius: 0 12rpx 12rpx 0;
  padding: 16rpx 20rpx;
  margin-bottom: 16rpx;
}

.risk-verdict-text {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.8;
}

/* ========================================
   #4 📅 本周前瞻
   ======================================== */

.wa-timeline {
  padding: 4rpx 0;
}

.wa-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 4rpx;
}

.wa-item:last-child {
  margin-bottom: 0;
}

.wa-left {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
  margin-right: 20rpx;
  width: 76rpx;
}

.wa-date-badge {
  width: 76rpx;
  padding: 6rpx 0;
  border-radius: 10rpx;
  text-align: center;
  flex-shrink: 0;
}

.wa-badge-event {
  background: rgba(255, 184, 0, 0.15);
}

.wa-badge-risk {
  background: rgba(231, 76, 60, 0.1);
}

.wa-date-text {
  font-size: 20rpx;
  font-weight: 700;
}

.wa-badge-event .wa-date-text {
  color: #FFB800;
}

.wa-badge-risk .wa-date-text {
  color: #e74c3c;
}

.wa-line {
  width: 2rpx;
  flex: 1;
  min-height: 24rpx;
  background: linear-gradient(180deg, #e8e8e8, transparent);
  margin-top: 6rpx;
}

.wa-right {
  flex: 1;
  padding-bottom: 24rpx;
}

.wa-item:last-child .wa-right {
  padding-bottom: 4rpx;
}

.wa-title-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 6rpx;
}

.wa-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #1a1a2e;
  flex: 1;
  line-height: 1.5;
}

.wa-impact-tag {
  flex-shrink: 0;
  margin-top: 2rpx;
}

.wa-risk-note {
  background: rgba(231, 76, 60, 0.04);
  border-left: 2rpx solid rgba(231, 76, 60, 0.3);
  padding: 8rpx 12rpx;
  border-radius: 0 8rpx 8rpx 0;
  margin-top: 6rpx;
}

.wa-risk-prob {
  display: block;
  font-size: 20rpx;
  color: #e74c3c;
  font-weight: 600;
  margin-bottom: 4rpx;
}

.wa-risk-response {
  display: block;
  font-size: 22rpx;
  color: #888;
  line-height: 1.5;
}

/* ========================================
   #5 🎰 市场在赌什么（默认折叠）
   ======================================== */

.pm-hook-row {
  padding: 4rpx 0 12rpx;
  border-bottom: 1rpx solid #f5f5f5;
  margin-bottom: 4rpx;
}

.pm-hook-text {
  font-size: 24rpx;
  color: #666;
  font-weight: 500;
}

.pm-list {
  margin-top: 4rpx;
}

.pm-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.pm-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.pm-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.pm-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #1a1a2e;
  flex: 1;
  margin-right: 12rpx;
}

.pm-source {
  font-size: 18rpx;
  color: #bbb;
  background: #f5f5f5;
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.pm-bar-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.pm-bar-track {
  flex: 1;
  height: 16rpx;
  background: #f0f0f0;
  border-radius: 8rpx;
  overflow: hidden;
}

.pm-bar-fill {
  height: 100%;
  border-radius: 8rpx;
  background: linear-gradient(90deg, #2980b9, #FFB800);
  transition: width 1s cubic-bezier(0.4, 0, 0.2, 1);
}

.pm-probability {
  font-size: 32rpx;
  font-weight: 800;
  color: #FFB800;
  min-width: 80rpx;
  text-align: right;
}

.pm-change-row {
  margin-top: 6rpx;
}

.pm-change {
  font-size: 22rpx;
  font-weight: 500;
}

.pm-trend-up {
  color: #e74c3c;
}

.pm-trend-down {
  color: #27ae60;
}

.pm-trend-stable {
  color: #999;
}

/* ========================================
   #6 ⚡ 异动信号
   ======================================== */

.alert-list {
  margin-top: 4rpx;
}

.alert-item {
  padding: 16rpx;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
}

.alert-item:last-child {
  margin-bottom: 0;
}

.alert-content {
  width: 100%;
}

.alert-top-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.alert-danger {
  background: rgba(231, 76, 60, 0.06);
}

.alert-warning {
  background: rgba(241, 196, 15, 0.08);
}

.alert-info {
  background: rgba(39, 174, 96, 0.06);
}

.alert-icon {
  flex-shrink: 0;
}

.alert-text {
  font-size: 26rpx;
  color: #333;
  line-height: 1.6;
}

.alert-time {
  font-size: 22rpx;
  color: #bbb;
  flex-shrink: 0;
}

/* ========================================
   通用来源链接样式
   ======================================== */

.source-link {
  display: flex;
  align-items: center;
  gap: 4rpx;
  margin-top: 6rpx;
}

.source-link-text {
  font-size: 20rpx;
  color: #2980b9;
}

.source-link-icon {
  font-size: 22rpx;
  color: #2980b9;
  font-weight: 700;
}

.source-link-sm {
  margin-top: 8rpx;
}

.sm-flat-header .source-link {
  margin-top: 0;
  flex-shrink: 0;
}

/* ========================================
   数据更新时间
   ======================================== */

.data-footer {
  text-align: center;
  padding: 20rpx 32rpx 16rpx;
}

.footer-text {
  font-size: 20rpx;
  color: #bbb;
}

/* ========================================
   入场动画
   ======================================== */

.stagger-item {
  opacity: 0;
  transform: translateX(20rpx);
}

.stagger-show {
  animation: slideInRight 0.4s ease forwards;
}

@keyframes slideInRight {
  from {
    opacity: 0;
    transform: translateX(20rpx);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}
