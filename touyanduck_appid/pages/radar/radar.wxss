/* pages/radar/radar.wxss */
/* 雷达页样式 v5.0 — 对齐Skill §5+§4 + v1.3前端体验升级 */

.page-container {
  padding-bottom: 20rpx;
}

/* ========== 综合风险评分 ========== */
.risk-score-container {
  display: flex;
  justify-content: center;
  margin: 24rpx 0;
}

.risk-score-circle {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  transform: scale(0.6);
  opacity: 0;
  transition: all 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.score-circle-show {
  transform: scale(1);
  opacity: 1;
}

.risk-low {
  background: linear-gradient(135deg, rgba(39,174,96,0.15), rgba(39,174,96,0.05));
  border: 4rpx solid #27ae60;
}

.risk-medium {
  background: linear-gradient(135deg, rgba(241,196,15,0.15), rgba(241,196,15,0.05));
  border: 4rpx solid #f1c40f;
}

.risk-high {
  background: linear-gradient(135deg, rgba(231,76,60,0.15), rgba(231,76,60,0.05));
  border: 4rpx solid #e74c3c;
}

.risk-score-number {
  font-size: 56rpx;
  font-weight: 800;
  color: #333;
}

.risk-score-label {
  font-size: 24rpx;
  color: #666;
  margin-top: 4rpx;
}

.risk-advice {
  font-size: 26rpx;
  color: #555;
  text-align: center;
  line-height: 1.7;
  padding: 0 20rpx;
}

/* ========== 监控阈值表 ========== */
.monitor-table {
  border-radius: 10rpx;
  overflow: hidden;
  border: 1rpx solid #f0f0f0;
}

.monitor-row {
  display: flex;
  border-bottom: 1rpx solid #f0f0f0;
}

.monitor-row:last-child {
  border-bottom: none;
}

.monitor-header-row {
  background: #f8f9fc;
}

.monitor-header-row .monitor-cell {
  font-weight: 600;
  color: #1a1a2e;
  font-size: 22rpx;
}

.monitor-cell {
  padding: 14rpx 16rpx;
  font-size: 22rpx;
  color: #555;
  line-height: 1.5;
}

.cell-condition {
  width: 40%;
  flex-shrink: 0;
  border-right: 1rpx solid #f0f0f0;
  font-weight: 500;
  color: #e67e22;
}

.cell-action {
  flex: 1;
}

/* ========== 风险预警 ========== */
.risk-alert-list {
  margin-top: 4rpx;
}

.risk-alert-item {
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.risk-alert-item:last-child {
  margin-bottom: 0;
}

.ra-high {
  background: rgba(231, 76, 60, 0.05);
  border-left: 4rpx solid #e74c3c;
}

.ra-medium {
  background: rgba(241, 196, 15, 0.06);
  border-left: 4rpx solid #f1c40f;
}

.ra-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a2e;
  margin-bottom: 8rpx;
}

.ra-meta {
  display: flex;
  gap: 12rpx;
  margin-bottom: 10rpx;
}

.ra-badge {
  font-size: 20rpx;
  padding: 2rpx 12rpx;
  border-radius: 12rpx;
  font-weight: 500;
}

.ra-prob {
  background: rgba(52, 152, 219, 0.1);
  color: #2980b9;
}

.ra-impact {
  background: rgba(231, 76, 60, 0.1);
  color: #e74c3c;
}

.ra-response {
  font-size: 24rpx;
  color: #666;
  line-height: 1.6;
}

/* ========== 聪明钱三梯队 ========== */
.sm-tier-list {
  margin-top: 4rpx;
}

.sm-tier {
  margin-bottom: 20rpx;
}

.sm-tier:last-child {
  margin-bottom: 0;
}

.sm-tier-label {
  font-size: 24rpx;
  font-weight: 600;
  color: #FFB800;
  padding: 4rpx 0 8rpx;
  border-bottom: 1rpx dashed #f0f0f0;
  margin-bottom: 8rpx;
}

.sm-fund-list {
  margin-top: 4rpx;
}

.sm-fund-item {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding: 10rpx 0;
  border-bottom: 1rpx solid #f8f8f8;
}

.sm-fund-item:last-child {
  border-bottom: none;
}

.sm-fund-left {
  display: flex;
  align-items: center;
  flex-shrink: 0;
  margin-right: 16rpx;
}

.sm-fund-signal {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  margin-right: 8rpx;
}

.sm-bullish {
  background: #e74c3c;
  box-shadow: 0 0 6rpx rgba(231, 76, 60, 0.4);
}

.sm-bearish {
  background: #27ae60;
  box-shadow: 0 0 6rpx rgba(39, 174, 96, 0.4);
}

.sm-neutral {
  background: #f1c40f;
  box-shadow: 0 0 6rpx rgba(241, 196, 15, 0.4);
}

.sm-fund-name {
  font-size: 24rpx;
  font-weight: 600;
  color: #333;
  white-space: nowrap;
}

.sm-fund-action {
  font-size: 22rpx;
  color: #888;
  line-height: 1.5;
  text-align: right;
  flex: 1;
}

/* ========== 关键事件 ========== */
.event-list {
  margin-top: 4rpx;
}

.event-item {
  display: flex;
  align-items: flex-start;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.event-item:last-child {
  border-bottom: none;
}

.event-date {
  font-size: 24rpx;
  color: #FFB800;
  font-weight: 600;
  min-width: 100rpx;
  flex-shrink: 0;
}

.event-content {
  flex: 1;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.event-title {
  font-size: 26rpx;
  color: #333;
  flex: 1;
  margin-right: 12rpx;
}

/* ========== 异动监测 ========== */
.alert-list {
  margin-top: 4rpx;
}

.alert-item {
  display: flex;
  align-items: flex-start;
  padding: 16rpx;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
}

.alert-item:last-child {
  margin-bottom: 0;
}

.alert-danger {
  background: rgba(231, 76, 60, 0.06);
}

.alert-warning {
  background: rgba(241, 196, 15, 0.08);
}

.alert-info {
  background: rgba(39, 174, 96, 0.06);
}

.alert-icon {
  margin-right: 12rpx;
  flex-shrink: 0;
}

.alert-text {
  flex: 1;
  font-size: 26rpx;
  color: #333;
  line-height: 1.6;
}

.alert-time {
  font-size: 22rpx;
  color: #bbb;
  flex-shrink: 0;
  margin-left: 12rpx;
}

/* ========== v1.3 Fear & Greed 情绪指数 ========== */
.fg-container {
  padding: 8rpx 0;
}

.fg-bar {
  display: flex;
  align-items: center;
}

.fg-bar-label {
  font-size: 22rpx;
  color: #999;
  flex-shrink: 0;
}

.fg-bar-track {
  flex: 1;
  height: 14rpx;
  border-radius: 7rpx;
  margin: 0 16rpx;
  overflow: visible;
  position: relative;
  background: #eee;
}

.fg-bar-gradient {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  border-radius: 7rpx;
  background: linear-gradient(90deg, #27ae60, #f1c40f 40%, #e67e22 60%, #e74c3c);
}

.fg-pointer {
  position: absolute;
  top: -9rpx;
  transform: translateX(-50%);
  transition: left 1s cubic-bezier(0.4, 0, 0.2, 1);
}

.fg-pointer-dot {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  background: #fff;
  border: 4rpx solid #FFB800;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
}

.fg-score-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  margin-top: 20rpx;
}

.fg-score {
  font-size: 56rpx;
  font-weight: 800;
}

.fg-emoji {
  font-size: 36rpx;
}

.fg-label-tag {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
  font-weight: 500;
}

/* Fear & Greed 颜色系统 */
.fg-extreme-fear { color: #27ae60; }
.fg-fear { color: #27ae60; }
.fg-neutral { color: #f1c40f; }
.fg-greed { color: #e67e22; }
.fg-extreme-greed { color: #e74c3c; }

.fg-extreme-fear-bg { background: rgba(39, 174, 96, 0.1); color: #27ae60; }
.fg-fear-bg { background: rgba(39, 174, 96, 0.1); color: #27ae60; }
.fg-neutral-bg { background: rgba(241, 196, 15, 0.1); color: #d4a017; }
.fg-greed-bg { background: rgba(230, 126, 34, 0.1); color: #e67e22; }
.fg-extreme-greed-bg { background: rgba(231, 76, 60, 0.1); color: #e74c3c; }

.fg-history {
  display: flex;
  justify-content: center;
  gap: 40rpx;
  margin-top: 20rpx;
  padding: 16rpx 0 4rpx;
  border-top: 1rpx solid #f5f5f5;
}

.fg-history-item {
  text-align: center;
}

.fg-hist-label {
  display: block;
  font-size: 20rpx;
  color: #bbb;
  margin-bottom: 4rpx;
}

.fg-hist-value {
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
}

.fg-hist-diff {
  font-size: 20rpx;
  margin-left: 6rpx;
  font-weight: 500;
}

.fg-diff-up {
  color: #e74c3c;
}

.fg-diff-down {
  color: #27ae60;
}

/* ========== v1.3 预测市场 ========== */
.pm-list {
  margin-top: 4rpx;
}

.pm-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.pm-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.pm-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.pm-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #1a1a2e;
  flex: 1;
  margin-right: 12rpx;
}

.pm-source {
  font-size: 18rpx;
  color: #bbb;
  background: #f5f5f5;
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.pm-bar-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.pm-bar-track {
  flex: 1;
  height: 16rpx;
  background: #f0f0f0;
  border-radius: 8rpx;
  overflow: hidden;
}

.pm-bar-fill {
  height: 100%;
  border-radius: 8rpx;
  background: linear-gradient(90deg, #2980b9, #FFB800);
  transition: width 1s cubic-bezier(0.4, 0, 0.2, 1);
}

.pm-probability {
  font-size: 32rpx;
  font-weight: 800;
  color: #FFB800;
  min-width: 80rpx;
  text-align: right;
}

.pm-change-row {
  margin-top: 6rpx;
}

.pm-change {
  font-size: 22rpx;
  font-weight: 500;
}

.pm-trend-up {
  color: #e74c3c;
}

.pm-trend-down {
  color: #27ae60;
}

.pm-trend-stable {
  color: #999;
}

/* ========== 数据更新时间 ========== */
.data-footer {
  text-align: center;
  padding: 20rpx 32rpx 16rpx;
}

.footer-text {
  font-size: 20rpx;
  color: #bbb;
}

/* ========== 入场动画 ========== */
.stagger-item {
  opacity: 0;
  transform: translateX(20rpx);
}

.stagger-show {
  animation: slideInRight 0.4s ease forwards;
}

@keyframes slideInRight {
  from {
    opacity: 0;
    transform: translateX(20rpx);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}
