/* pages/radar/radar.wxss */
/* 雷达页样式 v4.0 — 对齐Skill §5+§4 */

.page-container {
  padding-bottom: 20rpx;
}

/* ========== 综合风险评分 ========== */
.risk-score-container {
  display: flex;
  justify-content: center;
  margin: 24rpx 0;
}

.risk-score-circle {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  transform: scale(0.6);
  opacity: 0;
  transition: all 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.score-circle-show {
  transform: scale(1);
  opacity: 1;
}

.risk-low {
  background: linear-gradient(135deg, rgba(39,174,96,0.15), rgba(39,174,96,0.05));
  border: 4rpx solid #27ae60;
}

.risk-medium {
  background: linear-gradient(135deg, rgba(241,196,15,0.15), rgba(241,196,15,0.05));
  border: 4rpx solid #f1c40f;
}

.risk-high {
  background: linear-gradient(135deg, rgba(231,76,60,0.15), rgba(231,76,60,0.05));
  border: 4rpx solid #e74c3c;
}

.risk-score-number {
  font-size: 56rpx;
  font-weight: 800;
  color: #333;
}

.risk-score-label {
  font-size: 24rpx;
  color: #666;
  margin-top: 4rpx;
}

.risk-advice {
  font-size: 26rpx;
  color: #555;
  text-align: center;
  line-height: 1.7;
  padding: 0 20rpx;
}

/* ========== 监控阈值表 ========== */
.monitor-table {
  border-radius: 10rpx;
  overflow: hidden;
  border: 1rpx solid #f0f0f0;
}

.monitor-row {
  display: flex;
  border-bottom: 1rpx solid #f0f0f0;
}

.monitor-row:last-child {
  border-bottom: none;
}

.monitor-header-row {
  background: #f8f9fc;
}

.monitor-header-row .monitor-cell {
  font-weight: 600;
  color: #1a1a2e;
  font-size: 22rpx;
}

.monitor-cell {
  padding: 14rpx 16rpx;
  font-size: 22rpx;
  color: #555;
  line-height: 1.5;
}

.cell-condition {
  width: 40%;
  flex-shrink: 0;
  border-right: 1rpx solid #f0f0f0;
  font-weight: 500;
  color: #e67e22;
}

.cell-action {
  flex: 1;
}

/* ========== 风险预警 ========== */
.risk-alert-list {
  margin-top: 4rpx;
}

.risk-alert-item {
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.risk-alert-item:last-child {
  margin-bottom: 0;
}

.ra-high {
  background: rgba(231, 76, 60, 0.05);
  border-left: 4rpx solid #e74c3c;
}

.ra-medium {
  background: rgba(241, 196, 15, 0.06);
  border-left: 4rpx solid #f1c40f;
}

.ra-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a2e;
  margin-bottom: 8rpx;
}

.ra-meta {
  display: flex;
  gap: 12rpx;
  margin-bottom: 10rpx;
}

.ra-badge {
  font-size: 20rpx;
  padding: 2rpx 12rpx;
  border-radius: 12rpx;
  font-weight: 500;
}

.ra-prob {
  background: rgba(52, 152, 219, 0.1);
  color: #2980b9;
}

.ra-impact {
  background: rgba(231, 76, 60, 0.1);
  color: #e74c3c;
}

.ra-response {
  font-size: 24rpx;
  color: #666;
  line-height: 1.6;
}

/* ========== 聪明钱三梯队 ========== */
.sm-tier-list {
  margin-top: 4rpx;
}

.sm-tier {
  margin-bottom: 20rpx;
}

.sm-tier:last-child {
  margin-bottom: 0;
}

.sm-tier-label {
  font-size: 24rpx;
  font-weight: 600;
  color: #FFB800;
  padding: 4rpx 0 8rpx;
  border-bottom: 1rpx dashed #f0f0f0;
  margin-bottom: 8rpx;
}

.sm-fund-list {
  margin-top: 4rpx;
}

.sm-fund-item {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding: 10rpx 0;
  border-bottom: 1rpx solid #f8f8f8;
}

.sm-fund-item:last-child {
  border-bottom: none;
}

.sm-fund-left {
  display: flex;
  align-items: center;
  flex-shrink: 0;
  margin-right: 16rpx;
}

.sm-fund-signal {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  margin-right: 8rpx;
}

.sm-bullish {
  background: #e74c3c;
  box-shadow: 0 0 6rpx rgba(231, 76, 60, 0.4);
}

.sm-bearish {
  background: #27ae60;
  box-shadow: 0 0 6rpx rgba(39, 174, 96, 0.4);
}

.sm-neutral {
  background: #f1c40f;
  box-shadow: 0 0 6rpx rgba(241, 196, 15, 0.4);
}

.sm-fund-name {
  font-size: 24rpx;
  font-weight: 600;
  color: #333;
  white-space: nowrap;
}

.sm-fund-action {
  font-size: 22rpx;
  color: #888;
  line-height: 1.5;
  text-align: right;
  flex: 1;
}

/* ========== 关键事件 ========== */
.event-list {
  margin-top: 4rpx;
}

.event-item {
  display: flex;
  align-items: flex-start;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.event-item:last-child {
  border-bottom: none;
}

.event-date {
  font-size: 24rpx;
  color: #FFB800;
  font-weight: 600;
  min-width: 100rpx;
  flex-shrink: 0;
}

.event-content {
  flex: 1;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.event-title {
  font-size: 26rpx;
  color: #333;
  flex: 1;
  margin-right: 12rpx;
}

/* ========== 异动监测 ========== */
.alert-list {
  margin-top: 4rpx;
}

.alert-item {
  display: flex;
  align-items: flex-start;
  padding: 16rpx;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
}

.alert-item:last-child {
  margin-bottom: 0;
}

.alert-danger {
  background: rgba(231, 76, 60, 0.06);
}

.alert-warning {
  background: rgba(241, 196, 15, 0.08);
}

.alert-info {
  background: rgba(39, 174, 96, 0.06);
}

.alert-icon {
  margin-right: 12rpx;
  flex-shrink: 0;
}

.alert-text {
  flex: 1;
  font-size: 26rpx;
  color: #333;
  line-height: 1.6;
}

.alert-time {
  font-size: 22rpx;
  color: #bbb;
  flex-shrink: 0;
  margin-left: 12rpx;
}

/* ========== 数据截止时间 ========== */
.data-footer {
  text-align: center;
  padding: 24rpx 32rpx 16rpx;
}

.footer-text {
  font-size: 20rpx;
  color: #bbb;
}

/* ========== 入场动画 ========== */
.stagger-item {
  opacity: 0;
  transform: translateX(20rpx);
}

.stagger-show {
  animation: slideInRight 0.4s ease forwards;
}

@keyframes slideInRight {
  from {
    opacity: 0;
    transform: translateX(20rpx);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}
