<!--pages/radar/radar.wxml-->
<!-- 雷达页 v4.0：对齐Skill §5+§4 -->

<skeleton type="radar" loading="{{loading}}" />

<view class="page-container safe-bottom page-fade-in" wx:if="{{!loading}}">

  <!-- 风险红绿灯（7项） -->
  <section-card title="风险红绿灯">
    <traffic-light lights="{{trafficLights}}" />
  </section-card>

  <!-- 综合风险评分 -->
  <section-card title="综合风险评分">
    <view class="risk-score-container">
      <view class="risk-score-circle {{riskClassName}} {{animateReady ? 'score-circle-show' : ''}}">
        <view class="risk-score-number">{{displayRiskScore}}</view>
        <view class="risk-score-label">{{riskLabel}}</view>
      </view>
    </view>
    <view class="risk-advice">{{riskAdvice}}</view>
  </section-card>

  <!-- 监控阈值表 -->
  <section-card title="关键监控阈值" collapsible="{{true}}" expanded="{{true}}" wx:if="{{monitorTable.length}}">
    <view class="monitor-table">
      <view class="monitor-row monitor-header-row">
        <view class="monitor-cell cell-condition">触发条件</view>
        <view class="monitor-cell cell-action">应对动作</view>
      </view>
      <view class="monitor-row stagger-item {{animateReady ? 'stagger-show' : ''}}" 
            wx:for="{{monitorTable}}" wx:key="index"
            style="animation-delay: {{index * 60}}ms">
        <view class="monitor-cell cell-condition">{{item.condition}}</view>
        <view class="monitor-cell cell-action">{{item.action}}</view>
      </view>
    </view>
  </section-card>

  <!-- 风险提示（概率+影响+应对） -->
  <section-card title="风险预警" collapsible="{{true}}" expanded="{{true}}" borderColor="#e74c3c" wx:if="{{riskAlerts.length}}">
    <view class="risk-alert-list">
      <view class="risk-alert-item {{item.levelClass}} stagger-item {{animateReady ? 'stagger-show' : ''}}" 
            wx:for="{{riskAlerts}}" wx:key="index"
            style="animation-delay: {{(index + 3) * 80}}ms">
        <view class="ra-title">{{item.title}}</view>
        <view class="ra-meta">
          <view class="ra-badge ra-prob">概率 {{item.probability}}</view>
          <view class="ra-badge ra-impact">影响 {{item.impact}}</view>
        </view>
        <view class="ra-response">{{item.response}}</view>
      </view>
    </view>
  </section-card>

  <!-- 聪明钱三梯队详情 -->
  <section-card title="聪明钱动向" collapsible="{{true}}" expanded="{{true}}" wx:if="{{smartMoneyDetail.length}}">
    <view class="sm-tier-list">
      <view class="sm-tier" wx:for="{{smartMoneyDetail}}" wx:key="tier">
        <view class="sm-tier-label">{{item.tier}}</view>
        <view class="sm-fund-list">
          <view class="sm-fund-item stagger-item {{animateReady ? 'stagger-show' : ''}}" 
                wx:for="{{item.funds}}" wx:for-item="fund" wx:key="name"
                style="animation-delay: {{(index + 6) * 60}}ms">
            <view class="sm-fund-left">
              <view class="sm-fund-signal sm-{{fund.signal}}"></view>
              <view class="sm-fund-name">{{fund.name}}</view>
            </view>
            <view class="sm-fund-action">{{fund.action}}</view>
          </view>
        </view>
      </view>
    </view>
  </section-card>

  <!-- 本周关键事件 -->
  <section-card title="本周关键事件" collapsible="{{true}}" expanded="{{true}}">
    <view class="event-list">
      <view class="event-item stagger-item {{animateReady ? 'stagger-show' : ''}}" 
            wx:for="{{events}}" wx:key="index"
            style="animation-delay: {{index * 60}}ms">
        <view class="event-date">{{item.date}}</view>
        <view class="event-content">
          <view class="event-title">{{item.title}}</view>
          <view class="tag {{item.impactTagClass}}">{{item.impactLabel}}</view>
        </view>
      </view>
    </view>
  </section-card>

  <!-- 异动监测 -->
  <section-card title="异动监测" collapsible="{{true}}" expanded="{{true}}">
    <view class="alert-list">
      <view class="alert-item {{item.bgClass}} stagger-item {{animateReady ? 'stagger-show' : ''}}" 
            wx:for="{{alerts}}" wx:key="index"
            style="animation-delay: {{(index + 5) * 60}}ms">
        <view class="alert-icon">{{item.icon}}</view>
        <view class="alert-text">{{item.text}}</view>
        <view class="alert-time">{{item.time}}</view>
      </view>
    </view>
  </section-card>

  <!-- 数据截止时间 -->
  <view class="data-footer" wx:if="{{dataTime}}">
    <text class="footer-text">时点说明 · {{dataTime}} | {{isCloud ? '云数据' : '本地缓存'}}</text>
  </view>
</view>
