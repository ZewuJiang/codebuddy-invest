<!--pages/radar/radar.wxml-->
<!-- 雷达页 v7.0：聪明钱最优先 — 动向#1 + 持仓#2 + 风险判断#3 -->

<skeleton type="radar" loading="{{loading}}" />

<view class="page-container safe-bottom page-fade-in" wx:if="{{!loading}}">

  <!-- ===== #1 🧠 聪明钱动向 ===== -->
  <section-card title="🧠 聪明钱动向" wx:if="{{smartMoneyFlat.length}}">
    <view class="sm-flat-list">

      <view class="sm-flat-item stagger-item {{animateReady ? 'stagger-show' : ''}}"
            wx:for="{{smartMoneyFlat}}" wx:key="name"
            style="animation-delay: {{index * 70}}ms">
        <view class="sm-flat-header">
          <view class="sm-flat-left">
            <view class="sm-fund-signal sm-{{item.signal}}"></view>
            <text class="sm-flat-name">{{item.name}}</text>
            <text class="sm-tier-badge" wx:if="{{item.tierOrder === 0}}">旗舰</text>
          </view>
          <view class="source-link" wx:if="{{item.source}}" bindtap="onSourceTap"
                data-url="{{item.url}}" data-source="{{item.source}}">
            <text class="source-link-text">{{item.source}}</text>
            <text class="source-link-icon" wx:if="{{item.url}}">›</text>
          </view>
        </view>
        <view class="sm-flat-action">{{item.action}}</view>
      </view>

    </view>
  </section-card>

  <!-- ===== #2 💼 聪明钱持仓（默认折叠） ===== -->
  <section-card title="💼 聪明钱持仓" wx:if="{{holdings.length}}">
    <view class="holdings-module">

      <view class="holdings-group" wx:for="{{holdings}}" wx:key="manager">
        <view class="holdings-header" bindtap="toggleHoldings" data-index="{{index}}">
          <view class="holdings-header-left">
            <text class="holdings-manager">{{item.manager}}</text>
            <text class="holdings-aum">{{item.aum}}</text>
          </view>
          <view class="holdings-header-right">
            <text class="holdings-date">{{item.asOf}}</text>
            <text class="holdings-arrow">{{item.expanded ? '▲' : '▼'}}</text>
          </view>
        </view>

        <view class="holdings-body" wx:if="{{item.expanded}}">
          <view class="holdings-row" wx:for="{{item.positions}}" wx:for-item="pos" wx:key="symbol">
            <view class="holdings-row-left">
              <text class="holdings-rank">{{pos.rank}}</text>
              <view class="holdings-stock-info">
                <text class="holdings-stock-name">{{pos.name}}</text>
                <text class="holdings-stock-symbol">{{pos.symbol}}</text>
              </view>
            </view>
            <view class="holdings-row-right">
              <text class="holdings-weight">{{pos.weight}}</text>
              <text class="holdings-change" wx:if="{{pos.change}}">{{pos.change}}</text>
            </view>
          </view>
          <view class="holdings-footnote" wx:if="{{item.footnote}}">
            <text class="holdings-footnote-text">{{item.footnote}}</text>
          </view>
        </view>
      </view>

    </view>
  </section-card>

  <!-- ===== #3 🛡️ 风险判断 ===== -->
  <section-card title="🛡️ 风险判断">
    <view class="safety-card">

      <view class="risk-verdict" wx:if="{{riskAdvice}}">
        <text class="risk-verdict-text">{{riskAdvice}}</text>
      </view>

      <traffic-light lights="{{trafficLights}}" />

    </view>
  </section-card>

  <!-- ===== #4 📅 本周前瞻 ===== -->
  <section-card title="📅 本周前瞻" wx:if="{{weekAhead.length}}">
    <view class="wa-timeline">
      <view class="wa-item stagger-item {{animateReady ? 'stagger-show' : ''}}"
            wx:for="{{weekAhead}}" wx:key="index"
            style="animation-delay: {{index * 80}}ms">

        <view class="wa-left">
          <view class="wa-date-badge {{item.isRiskAlert ? 'wa-badge-risk' : 'wa-badge-event'}}">
            <text class="wa-date-text">{{item.date}}</text>
          </view>
          <view class="wa-line" wx:if="{{index < weekAhead.length - 1}}"></view>
        </view>

        <view class="wa-right">
          <view class="wa-title-row">
            <text class="wa-title">{{item.title}}</text>
            <view class="tag {{item.impactTagClass}} wa-impact-tag">{{item.impactLabel}}</view>
          </view>
          <view class="source-link" wx:if="{{item.source}}" bindtap="onSourceTap"
                data-url="{{item.url}}" data-source="{{item.source}}">
            <text class="source-link-text">📎 {{item.source}}</text>
            <text class="source-link-icon" wx:if="{{item.url}}">›</text>
          </view>
          <view class="wa-risk-note" wx:if="{{item.isRiskAlert && item.probability}}">
            <text class="wa-risk-prob">概率 {{item.probability}}</text>
            <text class="wa-risk-response">{{item.response}}</text>
          </view>
        </view>

      </view>
    </view>
  </section-card>

  <!-- ===== #5 📊 市场预测（默认折叠） ===== -->
  <section-card title="📊 市场预测" collapsible="{{true}}" expanded="{{false}}" wx:if="{{predictions.length}}">
    <view class="pm-list">
      <view class="pm-item stagger-item {{animateReady ? 'stagger-show' : ''}}"
            wx:for="{{predictions}}" wx:key="index"
            style="animation-delay: {{index * 80}}ms">
        <view class="pm-header">
          <text class="pm-title">{{item.title}}</text>
          <text class="pm-source">{{item.source}}</text>
        </view>
        <view class="pm-bar-row">
          <view class="pm-bar-track">
            <view class="pm-bar-fill" style="width: {{animateReady ? item.probability : 0}}%"></view>
          </view>
          <text class="pm-probability">{{item.probability}}%</text>
        </view>
        <view class="pm-change-row">
          <text class="pm-change {{item.trendClass}}">{{item.trendArrow}} 24h {{item.changeLabel}}</text>
        </view>
      </view>
    </view>
  </section-card>

  <!-- ===== #6 ⚡ 异动信号（有数据才展示） ===== -->
  <section-card title="⚡ 异动信号" wx:if="{{alerts.length}}">
    <view class="alert-list">
      <view class="alert-item {{item.bgClass}} stagger-item {{animateReady ? 'stagger-show' : ''}}"
            wx:for="{{alerts}}" wx:key="index"
            style="animation-delay: {{index * 60}}ms">
        <view class="alert-content">
          <view class="alert-top-row">
            <view class="alert-icon">{{item.icon}}</view>
            <view class="alert-time">{{item.time}}</view>
          </view>
          <view class="alert-text">{{item.text}}</view>
          <view class="source-link source-link-sm" wx:if="{{item.source}}" bindtap="onSourceTap"
                data-url="{{item.url}}" data-source="{{item.source}}">
            <text class="source-link-text">{{item.source}}</text>
            <text class="source-link-icon" wx:if="{{item.url}}">›</text>
          </view>
        </view>
      </view>
    </view>
  </section-card>

  <!-- 数据更新时间 -->
  <view class="data-footer" wx:if="{{dataTime}}">
    <text class="footer-text">更新时间 · {{dataTime}}</text>
  </view>

</view>
