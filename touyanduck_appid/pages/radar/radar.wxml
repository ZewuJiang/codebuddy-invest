<!--pages/radar/radar.wxml-->
<!-- 雷达页 v5.0：对齐Skill §5+§4 + v1.3前端体验升级 -->

<skeleton type="radar" loading="{{loading}}" />

<view class="page-container safe-bottom page-fade-in" wx:if="{{!loading}}">

  <!-- 风险红绿灯（7项） -->
  <section-card title="风险红绿灯">
    <traffic-light lights="{{trafficLights}}" />
  </section-card>

  <!-- v1.3 市场情绪指数 Fear & Greed -->
  <section-card title="市场情绪指数" wx:if="{{fearGreed}}">
    <view class="fg-container">
      <!-- 情绪条 -->
      <view class="fg-bar">
        <view class="fg-bar-label">恐惧</view>
        <view class="fg-bar-track">
          <view class="fg-bar-gradient"></view>
          <view class="fg-pointer" style="left: {{animateReady ? fearGreed.value : 0}}%">
            <view class="fg-pointer-dot"></view>
          </view>
        </view>
        <view class="fg-bar-label">贪婪</view>
      </view>
      <!-- 分数+标签 -->
      <view class="fg-score-row">
        <text class="fg-score {{fgInfo.colorClass}}">{{displayFGValue}}</text>
        <text class="fg-emoji">{{fgInfo.emoji}}</text>
        <text class="fg-label-tag {{fgInfo.colorClass}}-bg">{{fgInfo.cnLabel}}</text>
      </view>
      <!-- 历史对比 -->
      <view class="fg-history">
        <view class="fg-history-item">
          <text class="fg-hist-label">昨日</text>
          <text class="fg-hist-value">{{fearGreed.previousClose}}</text>
          <text class="fg-hist-diff {{fgPrevDiff >= 0 ? 'fg-diff-up' : 'fg-diff-down'}}">{{fgPrevDiff >= 0 ? '+' : ''}}{{fgPrevDiff}}</text>
        </view>
        <view class="fg-history-item">
          <text class="fg-hist-label">一周前</text>
          <text class="fg-hist-value">{{fearGreed.oneWeekAgo}}</text>
          <text class="fg-hist-diff {{fgWeekDiff >= 0 ? 'fg-diff-up' : 'fg-diff-down'}}">{{fgWeekDiff >= 0 ? '+' : ''}}{{fgWeekDiff}}</text>
        </view>
        <view class="fg-history-item" wx:if="{{fearGreed.oneMonthAgo}}">
          <text class="fg-hist-label">一月前</text>
          <text class="fg-hist-value">{{fearGreed.oneMonthAgo}}</text>
        </view>
      </view>
    </view>
  </section-card>

  <!-- v1.3 预测市场 -->
  <section-card title="预测市场" collapsible="{{true}}" expanded="{{true}}" wx:if="{{predictions.length}}">
    <view class="pm-list">
      <view class="pm-item stagger-item {{animateReady ? 'stagger-show' : ''}}" 
            wx:for="{{predictions}}" wx:key="index"
            style="animation-delay: {{index * 80}}ms">
        <view class="pm-header">
          <text class="pm-title">{{item.title}}</text>
          <text class="pm-source">{{item.source}}</text>
        </view>
        <view class="pm-bar-row">
          <view class="pm-bar-track">
            <view class="pm-bar-fill" style="width: {{animateReady ? item.probability : 0}}%"></view>
          </view>
          <text class="pm-probability">{{item.probability}}%</text>
        </view>
        <view class="pm-change-row">
          <text class="pm-change {{item.trendClass}}">{{item.trendArrow}} 24h {{item.changeLabel}}</text>
        </view>
      </view>
    </view>
  </section-card>

  <!-- 综合风险评分 -->
  <section-card title="综合风险评分">
    <view class="risk-score-container">
      <view class="risk-score-circle {{riskClassName}} {{animateReady ? 'score-circle-show' : ''}}">
        <view class="risk-score-number">{{displayRiskScore}}</view>
        <view class="risk-score-label">{{riskLabel}}</view>
      </view>
    </view>
    <view class="risk-advice">{{riskAdvice}}</view>
  </section-card>

  <!-- 监控阈值表 -->
  <section-card title="关键监控阈值" collapsible="{{true}}" expanded="{{true}}" wx:if="{{monitorTable.length}}">
    <view class="monitor-table">
      <view class="monitor-row monitor-header-row">
        <view class="monitor-cell cell-condition">触发条件</view>
        <view class="monitor-cell cell-action">应对动作</view>
      </view>
      <view class="monitor-row stagger-item {{animateReady ? 'stagger-show' : ''}}" 
            wx:for="{{monitorTable}}" wx:key="index"
            style="animation-delay: {{index * 60}}ms">
        <view class="monitor-cell cell-condition">{{item.condition}}</view>
        <view class="monitor-cell cell-action">{{item.action}}</view>
      </view>
    </view>
  </section-card>

  <!-- 风险提示（概率+影响+应对） -->
  <section-card title="风险预警" collapsible="{{true}}" expanded="{{true}}" borderColor="#e74c3c" wx:if="{{riskAlerts.length}}">
    <view class="risk-alert-list">
      <view class="risk-alert-item {{item.levelClass}} stagger-item {{animateReady ? 'stagger-show' : ''}}" 
            wx:for="{{riskAlerts}}" wx:key="index"
            style="animation-delay: {{(index + 3) * 80}}ms">
        <view class="ra-title">{{item.title}}</view>
        <view class="ra-meta">
          <view class="ra-badge ra-prob">概率 {{item.probability}}</view>
          <view class="ra-badge ra-impact">影响 {{item.impact}}</view>
        </view>
        <view class="ra-response">{{item.response}}</view>
      </view>
    </view>
  </section-card>

  <!-- 聪明钱三梯队详情 -->
  <section-card title="聪明钱动向" collapsible="{{true}}" expanded="{{true}}" wx:if="{{smartMoneyDetail.length}}">
    <view class="sm-tier-list">
      <view class="sm-tier" wx:for="{{smartMoneyDetail}}" wx:key="tier">
        <view class="sm-tier-label">{{item.tier}}</view>
        <view class="sm-fund-list">
          <view class="sm-fund-item stagger-item {{animateReady ? 'stagger-show' : ''}}" 
                wx:for="{{item.funds}}" wx:for-item="fund" wx:key="name"
                style="animation-delay: {{(index + 6) * 60}}ms">
            <view class="sm-fund-left">
              <view class="sm-fund-signal sm-{{fund.signal}}"></view>
              <view class="sm-fund-name">{{fund.name}}</view>
            </view>
            <view class="sm-fund-action">{{fund.action}}</view>
          </view>
        </view>
      </view>
    </view>
  </section-card>

  <!-- 本周关键事件 -->
  <section-card title="本周关键事件" collapsible="{{true}}" expanded="{{true}}">
    <view class="event-list">
      <view class="event-item stagger-item {{animateReady ? 'stagger-show' : ''}}" 
            wx:for="{{events}}" wx:key="index"
            style="animation-delay: {{index * 60}}ms">
        <view class="event-date">{{item.date}}</view>
        <view class="event-content">
          <view class="event-title">{{item.title}}</view>
          <view class="tag {{item.impactTagClass}}">{{item.impactLabel}}</view>
        </view>
      </view>
    </view>
  </section-card>

  <!-- 异动监测 -->
  <section-card title="异动监测" collapsible="{{true}}" expanded="{{true}}">
    <view class="alert-list">
      <view class="alert-item {{item.bgClass}} stagger-item {{animateReady ? 'stagger-show' : ''}}" 
            wx:for="{{alerts}}" wx:key="index"
            style="animation-delay: {{(index + 5) * 60}}ms">
        <view class="alert-icon">{{item.icon}}</view>
        <view class="alert-text">{{item.text}}</view>
        <view class="alert-time">{{item.time}}</view>
      </view>
    </view>
  </section-card>

  <!-- v1.3 双层数据状态栏 -->
  <view class="ds-footer" wx:if="{{dataTime}}">
    <view class="ds-row-primary">
      <view class="ds-dot {{isCloud ? 'ds-dot-cloud' : 'ds-dot-cache'}}"></view>
      <text class="ds-source">{{isCloud ? '云数据' : '本地缓存'}}</text>
      <text class="ds-sep">·</text>
      <text class="ds-time">{{dataFreshness || dataTime}}</text>
    </view>
    <view class="ds-row-meta" wx:if="{{dataMeta}}">
      <text class="ds-type-tag ds-type-{{dataMeta.sourceType === 'heavy_analysis' ? 'heavy' : 'realtime'}}" wx:if="{{dataMeta.sourceType}}">{{dataMeta.sourceType === 'heavy_analysis' ? 'AI深度分析' : (dataMeta.sourceType === 'realtime_quote' ? '实时行情' : '突发新闻')}}</text>
      <text class="ds-version" wx:if="{{dataMeta.skillVersion}}">Skill {{dataMeta.skillVersion}}</text>
    </view>
  </view>
</view>
